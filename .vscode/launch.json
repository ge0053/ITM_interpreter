
{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run stream_inotify",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/stream_inotify",
            "args": [
                "${workspaceFolder}/src/test.bin"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build"
        }
    ]
}
